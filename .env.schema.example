# Example schema for dotenv-guard.
# Each key is a variable name; the value is its rule.
#   type:     string | url | port | enum | secret
#   required: true | false
#   values:   allowed values (only for type: enum)

DATABASE_URL: { type: url, required: true }
PORT: { type: port, required: true }
LOG_LEVEL: { type: enum, values: [debug, info, warn, error], required: false }
API_SECRET: { type: secret, required: true }
